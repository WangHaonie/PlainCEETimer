    <SolidColorBrush x:Key="ForeText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackText" Color="#191919"/>

    <SolidColorBrush x:Key="BorderTextBox" Color="#2C2C2C"/>
    <SolidColorBrush x:Key="BorderTextBoxFocused" Color="#4CC2FF"/>

    <SolidColorBrush x:Key="ForeButtonDisabled" Color="#CCCCCC"/>
