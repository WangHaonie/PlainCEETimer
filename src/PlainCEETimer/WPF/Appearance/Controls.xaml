<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="clr-namespace:PlainCEETimer.WPF.Controls">

    <Style TargetType="Controls:FontFamilyInputBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Controls:FontFamilyInputBox}">
                    <Grid>
                        <Border x:Name="Border" SnapsToDevicePixels="True"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <Popup x:Name="PART_Popup" Placement="Bottom" StaysOpen="True" AllowsTransparency="True"
                            PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                            MaxHeight="{TemplateBinding PopupMaxHeight}">
                            <Border BorderThickness="1,0,1,1" SnapsToDevicePixels="True"
                                    Background="{DynamicResource BackText}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <ListBox x:Name="PART_ListBox" BorderThickness="0"
                                    SnapsToDevicePixels="True"
                                    VirtualizingPanel.IsVirtualizing="True"
                                    VirtualizingPanel.VirtualizationMode="Recycling"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    Foreground="{DynamicResource ForeText}"
                                    Background="{DynamicResource BackText}"/>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Controls:FontFamilyInputBox.IsFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderTextBoxFocused}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
