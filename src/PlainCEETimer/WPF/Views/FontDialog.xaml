<base:AppWindow x:Class="PlainCEETimer.WPF.Views.FontDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlainCEETimer.WPF.Views"
        xmlns:vm="clr-namespace:PlainCEETimer.WPF.ViewModels"
        xmlns:base="clr-namespace:PlainCEETimer.WPF.Controls"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=vm:FontDialogViewModel}"
        Title="字体设置 - 高考倒计时" ResizeMode="NoResize" Height="280" Width="420">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Margin="0,0,10,15" VerticalAlignment="Center"
                   Text="字体家族" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                 Margin="0,0,0,15" Padding="1,3,1,3" />
        
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Margin="0,0,10,15" VerticalAlignment="Center"
                   Text="字体粗细" />

        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal">
            <ComboBox Margin="0,0,15,15" Width="90" />
            <TextBlock VerticalAlignment="Center" Margin="0,0,10,15" Text="字体大小"/>
            <ComboBox Margin="0,0,0,15" Width="70" />
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,5"
                   Text="字体预览"/>
        <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                 AcceptsReturn="True" TextWrapping="Wrap" 
                 Margin="0,0,0,12" Padding="2"/>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="75" Height="23" Margin="0,0,15,0"/>
            <Button Content="保存" Width="75" Height="23"/>
        </StackPanel>
    </Grid>
</base:AppWindow>
