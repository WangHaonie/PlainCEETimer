<base:AppWindow x:Class="PlainCEETimer.WPF.Views.FontDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlainCEETimer.WPF.Views"
        xmlns:vm="clr-namespace:PlainCEETimer.WPF.ViewModels"
        xmlns:base="clr-namespace:PlainCEETimer.WPF.Controls"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=vm:FontDialogViewModel}"
        Title="字体设置 - 高考倒计时" ResizeMode="NoResize" Height="300" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Margin="0,0,10,15" VerticalAlignment="Center"
                   Text="字体家族" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                 Margin="0,0,0,15" Padding="1,3,1,3"
                 MaxLength="100"
                 Text="{Binding FontFamilyText, UpdateSourceTrigger=PropertyChanged, Delay=500}">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFontValid}" Value="False">
                            <Setter Property="BorderBrush" Value="Red" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
        
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Margin="0,0,10,15" VerticalAlignment="Center"
                   Text="字体粗细" />

        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal">
            <ComboBox Margin="0,0,15,15" Width="70"
                      ItemsSource="{Binding FontWeightCollection}"
                      SelectedItem="{Binding FontWeight, UpdateSourceTrigger=PropertyChanged}"
                      DisplayMemberPath="Display"/>
            <TextBlock VerticalAlignment="Center" Margin="0,0,10,15"
                       Text="字体大小"/>
            <ComboBox Margin="0,0,0,15" Width="70"
                      IsEditable="True"
                      Text="{Binding FontSizeText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                      ItemsSource="{Binding FontSizeCollection}"
                      DisplayMemberPath="Display"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,5"
                   Text="字体预览"/>

        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,12"
                BorderBrush="Gray">
            <Grid>
                <TextBox AcceptsReturn="True" TextWrapping="Wrap" MaxLength="200"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding PreviewText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{Binding PreviewFontFamily}"
                         FontWeight="{Binding FontWeight.FontWeight}"
                         FontSize="{Binding PreviewFontSize}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFontValid}" Value="False">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBlock Text="输入的字体无效！" Foreground="Red"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFontValid}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFontValid}" Value="False">
                            <Setter Property="BorderThickness" Value="1" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button IsDefault="True" Content="确定(_O)" Width="75" Height="23" Margin="0,0,15,0"
                    Command="{Binding SaveChangesCommand}"/>
            <Button IsCancel="True" Content="取消(_C)" Width="75" Height="23"
                    Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</base:AppWindow>
