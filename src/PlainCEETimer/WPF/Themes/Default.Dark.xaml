<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ForeText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackText" Color="#191919"/>

    <SolidColorBrush x:Key="BorderTextBox" Color="#2C2C2C"/>

    <SolidColorBrush x:Key="ForeButtonDisabled" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="BackButton" Color="#333333"/>
    <SolidColorBrush x:Key="BackButtonHot" Color="#454545"/>
    <SolidColorBrush x:Key="BackButtonClick" Color="#666666"/>
    <SolidColorBrush x:Key="BorderButton" Color="#9B9B9B"/>
    <SolidColorBrush x:Key="BorderButtonHot" Color="#9B9B9B"/>
    <SolidColorBrush x:Key="BorderButtonClick" Color="#9B9B9B"/>
    <SolidColorBrush x:Key="BorderButtonDisabled" Color="#404040"/>
</ResourceDictionary>