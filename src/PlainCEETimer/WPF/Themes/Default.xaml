<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style TargetType="Window">
        <Setter Property="Foreground" Value="{DynamicResource ForeText}"/>
        <Setter Property="Background" Value="{DynamicResource BackText}"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource ForeText}"/>
        <Setter Property="Background" Value="{DynamicResource BackText}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderTextBox}"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource ForeText}"/>
        <Setter Property="Background" Value="{DynamicResource BackButton}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderButton}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                        RecognizesAccessKey="True"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BackButtonHot}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderButtonHot}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource BackButtonClick}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderButtonClick}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ForeButtonDisabled}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderButtonDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>